# Discord Bot Token (get from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Command Prefix (optional - defaults to !)
COMMAND_PREFIX=!

# Readarr Configuration (Books)
# Note: Use Docker service names (readarr, readarr-audio, etc.) if bot runs in Docker
# Use localhost:PORT if running bot locally outside Docker
READARR_URL=http://readarr:8787
READARR_API_KEY=your_readarr_api_key_here

# Readarr Settings (check your Readarr Settings > Profiles)
ROOT_FOLDER_PATH=/data/books/user1/ebooks
QUALITY_PROFILE_ID=1
METADATA_PROFILE_ID=1

# Readarr Audiobooks Configuration (First Instance)
# Docker: http://readarr-audio:8787 | Local: http://localhost:8788
READARR_AUDIOBOOK_URL=http://readarr-audio:8787
READARR_AUDIOBOOK_API_KEY=your_audiobook_api_key_here
READARR_AUDIOBOOK_ROOT_FOLDER=/data/books/user1/audiobooks
READARR_AUDIOBOOK_QUALITY_PROFILE_ID=3
READARR_AUDIOBOOK_METADATA_PROFILE_ID=1

# Readarr2 Configuration (Second Ebooks Instance)
# Docker: http://readarr2:8787 | Local: http://localhost:8789
READARR2_URL=http://readarr2:8787
READARR2_API_KEY=your_readarr2_api_key_here
READARR2_ROOT_FOLDER=/data/books/user2/ebooks
READARR2_QUALITY_PROFILE_ID=1
READARR2_METADATA_PROFILE_ID=1

# Readarr-Audio2 Configuration (Second Audiobooks Instance)
# Docker: http://readarr-audio2:8787 | Local: http://localhost:8790
READARR_AUDIO2_URL=http://readarr-audio2:8787
READARR_AUDIO2_API_KEY=your_readarr_audio2_api_key_here
READARR_AUDIO2_ROOT_FOLDER=/data/books/user2/audiobooks
READARR_AUDIO2_QUALITY_PROFILE_ID=3
READARR_AUDIO2_METADATA_PROFILE_ID=1

# Sonarr Configuration (TV Shows)
# Docker: http://sonarr:8989 | Local: http://localhost:8989
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=your_sonarr_api_key_here
SONARR_ROOT_FOLDER=/tv
SONARR_QUALITY_PROFILE_ID=1

# Radarr Configuration (Movies)
# Docker: http://radarr:7878 | Local: http://localhost:7878
RADARR_URL=http://radarr:7878
RADARR_API_KEY=your_radarr_api_key_here
RADARR_ROOT_FOLDER=/movies
RADARR_QUALITY_PROFILE_ID=1

# Trailarr Configuration (YouTube trailer integration)
# Automatically adds YouTube trailer links to new movie and TV notifications
TRAILARR_URL=http://trailarr:7889
TRAILARR_ENABLED=true

# TMDb API Configuration (required for trailer lookups)
# Get your API key from https://www.themoviedb.org/settings/api
# The bot uses TMDb API directly to fetch YouTube trailer URLs
TMDB_API_KEY=your_tmdb_api_key_here

# Episode Suppressor Configuration
# Prevents episode notification flooding when new series are added
EPISODE_SUPPRESSION_HOURS=24
EPISODE_SUPPRESSION_CHANNEL=general

# Manual Import Notifier Configuration
# Polls Readarr instances for manual imports (not covered by Notifiarr webhooks)
MANUAL_IMPORT_POLL_INTERVAL=60
MANUAL_IMPORT_CHANNEL=general

# Prowlarr Fallback Script (optional - path to prowlarr-book-fallback.sh)
# PROWLARR_FALLBACK_SCRIPT=/opt/scripts/prowlarr-book-fallback.sh
